{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pi-gui",
  "version": "0.1.0",
  "identifier": "me.mingeon.pi-gui",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "pnpm dev:web",
      "wait": false
    },
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "π",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist-backend": "backend"
    }
  },
  "plugins": {}
}
